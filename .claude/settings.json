{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo [hook] file modified: $env:CLAUDE_TOOL_INPUT"
          }
        ]
      }
    ]
  }
}
